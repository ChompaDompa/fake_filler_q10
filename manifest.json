{
  "manifest_version": 3,
  "name": "Diligenciar usuario",
  "version": "1.3",
  "description": "Rellena un formulario de usuario con datos aleatorios",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "script/background.js"
  },
  "omnibox": {
    "keyword": "jk"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "webNavigation",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://*.q10.com/*",
    "https://appservicejack1-staging.azurewebsites.net/*"
  ],
  "icons": {
    "16": "img/icon16.png",
    "32": "img/icon32.png",
    "48": "img/icon48.png",
    "128": "img/icon128.png"
  }
}
