{
  "manifest_version": 3,
  "name": "Diligenciar usuario",
  "version": "1.0",
  "description": "Rellena un formulario de usuario con datos aleatorios",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["scripting", "activeTab"],
  "icons": {
    "16": "img/icon16.png",
    "32": "img/icon32.png",
    "48": "img/icon48.png",
    "128": "img/icon128.png"
  }
}
